#!/usr/bin/env bash
# Pre-push hook to run tests before pushing
# This ensures code quality is maintained

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "Running pre-push checks..."
echo ""

# Activate virtual environment if available
if [ -f ".venv/bin/activate" ]; then
    echo -e "${GREEN}Activating virtual environment...${NC}"
    source .venv/bin/activate
else
    echo -e "${YELLOW}Warning: No .venv found, using system Python${NC}"
fi

# Check if pytest is available
if ! command -v pytest &> /dev/null; then
    echo -e "${RED}Error: pytest not found${NC}"
    echo "Please install test dependencies:"
    echo "  pip install -e \".[dev]\""
    echo ""
    echo -e "To skip this check: ${YELLOW}git push --no-verify${NC}"
    exit 1
fi

# Run pytest
echo -e "${GREEN}Running tests...${NC}"
echo ""

if pytest; then
    echo ""
    echo -e "${GREEN}All tests passed!${NC}"
    exit 0
else
    echo ""
    echo -e "${RED}Tests failed! Push aborted.${NC}"
    echo ""
    echo "Please fix the failing tests before pushing."
    echo ""
    echo -e "To skip this check: ${YELLOW}git push --no-verify${NC}"
    exit 1
fi

#!/usr/bin/env bash
# Pre-commit hook to enforce version bumping (once per branch/PR)
# Compares version against main branch, so only one bump is needed per feature branch.
# Falls back to HEAD comparison if main branch doesn't exist.

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Check if any Python files in cli/simpletask/ are modified (excluding __pycache__)
CODE_CHANGED=false
CHANGED_CODE_FILES=()
for file in $STAGED_FILES; do
    if [[ $file == cli/simpletask/*.py ]] || [[ $file == cli/simpletask/**/*.py ]]; then
        if [[ $file != *__pycache__* ]]; then
            CODE_CHANGED=true
            CHANGED_CODE_FILES+=("$file")
        fi
    fi
done

# If no code changes, allow commit
if [ "$CODE_CHANGED" = false ]; then
    exit 0
fi

# Check if version files are being committed
INIT_STAGED=false
PYPROJECT_STAGED=false
for file in $STAGED_FILES; do
    if [[ $file == "cli/simpletask/__init__.py" ]]; then
        INIT_STAGED=true
    fi
    if [[ $file == "pyproject.toml" ]]; then
        PYPROJECT_STAGED=true
    fi
done

# Get version from main branch (one bump per branch/PR, not per commit)
# Fall back to HEAD if main doesn't exist, then to 0.0.0 for initial commits
CURRENT_VERSION=$(git show main:cli/simpletask/__init__.py 2>/dev/null | grep "^__version__" | cut -d'"' -f2)
if [ -z "$CURRENT_VERSION" ]; then
    CURRENT_VERSION=$(git show HEAD:cli/simpletask/__init__.py 2>/dev/null | grep "^__version__" | cut -d'"' -f2)
fi
if [ -z "$CURRENT_VERSION" ]; then
    CURRENT_VERSION="0.0.0"
fi

# Get staged version from __init__.py
STAGED_INIT_VERSION=$(git show :cli/simpletask/__init__.py 2>/dev/null | grep "^__version__" | cut -d'"' -f2)
if [ -z "$STAGED_INIT_VERSION" ]; then
    STAGED_INIT_VERSION=$CURRENT_VERSION
fi

# Get staged version from pyproject.toml
STAGED_PYPROJECT_VERSION=$(git show :pyproject.toml 2>/dev/null | grep "^version = " | cut -d'"' -f2)
if [ -z "$STAGED_PYPROJECT_VERSION" ]; then
    STAGED_PYPROJECT_VERSION=$CURRENT_VERSION
fi

# Check if versions match between files
if [ "$STAGED_INIT_VERSION" != "$STAGED_PYPROJECT_VERSION" ]; then
    echo -e "${RED}Error: Version mismatch between files${NC}"
    echo "  cli/simpletask/__init__.py: ${STAGED_INIT_VERSION}"
    echo "  pyproject.toml:             ${STAGED_PYPROJECT_VERSION}"
    echo ""
    echo "Please ensure both files have the same version."
    echo ""
    echo -e "To skip this check: ${YELLOW}git commit --no-verify${NC}"
    exit 1
fi

# Check if version actually changed (increased)
if [ "$STAGED_INIT_VERSION" != "$CURRENT_VERSION" ]; then
    # Version changed - verify it increased (simple string comparison for semver)
    echo -e "${GREEN}Version bumped: ${CURRENT_VERSION} -> ${STAGED_INIT_VERSION}${NC}"
    
    # Run code quality checks after version bump is confirmed
    echo -e "${YELLOW}Running code quality checks...${NC}"
    
    # Check if .venv exists and activate it
    if [ -d ".venv" ]; then
        source .venv/bin/activate
    fi
    
    # Run ruff
    echo -n "  - Running ruff... "
    RUFF_OUTPUT=$(ruff check . 2>&1) || {
        echo -e "${RED}✗${NC}"
        echo -e "${RED}Ruff check failed:${NC}"
        echo "$RUFF_OUTPUT" | head -30
        echo -e "To skip this check: ${YELLOW}git commit --no-verify${NC}"
        exit 1
    }
    echo -e "${GREEN}✓${NC}"
    
    # Run ruff format check
    echo -n "  - Running ruff format... "
    FORMAT_OUTPUT=$(ruff format --check . 2>&1) || {
        echo -e "${RED}✗${NC}"
        echo -e "${RED}Code formatting issues found:${NC}"
        echo "$FORMAT_OUTPUT" | head -30
        echo -e "${YELLOW}Run 'ruff format .' to fix formatting.${NC}"
        echo -e "To skip this check: ${YELLOW}git commit --no-verify${NC}"
        exit 1
    }
    echo -e "${GREEN}✓${NC}"
    
    # Run mypy (allow to fail with warning, since repo has pre-existing issues)
    echo -n "  - Running mypy... "
    MYPY_OUTPUT=$(mypy cli/simpletask 2>&1) && {
        echo -e "${GREEN}✓${NC}"
    } || {
        echo -e "${YELLOW}⚠${NC}"
        echo -e "${YELLOW}Note: mypy found issues:${NC}"
        echo "$MYPY_OUTPUT" | head -20
        # Don't exit - mypy issues won't block commits
    }
    
    exit 0
fi

# If code changed but version not bumped, show error
if [ "$CODE_CHANGED" = true ] && [ "$STAGED_INIT_VERSION" = "$CURRENT_VERSION" ]; then
    echo -e "${RED}Error: Code changes detected but version not bumped${NC}"
    echo -e "${YELLOW}Modified files in cli/simpletask/:${NC}"
    for file in "${CHANGED_CODE_FILES[@]}"; do
        echo "  - $file"
    done
    echo ""
    echo -e "${YELLOW}Please bump the version in BOTH files:${NC}"
    echo "  1. cli/simpletask/__init__.py (__version__ = \"x.y.z\")"
    echo "  2. pyproject.toml (version = \"x.y.z\")"
    echo ""
    echo "Current version: ${CURRENT_VERSION}"
    echo ""
    echo "Follow semantic versioning:"
    echo "  - MINOR (0.x.0): New features, enhancements"
    echo "  - PATCH (0.0.x): Bug fixes, small changes"
    echo ""
    echo -e "${RED}Note: Do NOT bump the MAJOR version without explicit approval.${NC}"
    echo ""
    echo -e "To skip this check: ${YELLOW}git commit --no-verify${NC}"
    exit 1
fi

# If version files staged but version unchanged
if [ "$INIT_STAGED" = true ] || [ "$PYPROJECT_STAGED" = true ]; then
    if [ "$STAGED_INIT_VERSION" = "$CURRENT_VERSION" ]; then
        echo -e "${RED}Error: Version files modified but version number unchanged${NC}"
        echo "Current version: ${CURRENT_VERSION}"
        echo "Staged version:  ${STAGED_INIT_VERSION}"
        echo ""
        echo "Please update the version number in both:"
        echo "  - cli/simpletask/__init__.py"
        echo "  - pyproject.toml"
        echo ""
        echo -e "To skip this check: ${YELLOW}git commit --no-verify${NC}"
        exit 1
    fi
fi

exit 0
